# Git
.git
.gitignore

# Python build artifacts
dist/
*.egg-info/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/

# Secrets — never bake into image
.streamlit/secrets.toml
pymlens/.streamlit/secrets.toml
expressions.txt
*.env
.env*

# Local DB — mounted as a volume at runtime
# (don't copy it into the image)
~/.pymlens/

# IDE / OS
.vscode/
.idea/
*.DS_Store
Thumbs.db

# Docs / screenshots (not needed at runtime)
*.png
*.jpg
*.gif
README.md
